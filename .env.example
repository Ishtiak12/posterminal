# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-here

# Payment Gateway Configuration
PAYMENT_API_URL=https://api.payment-gateway.com
PAYMENT_API_KEY=your_api_key_here
OUTLET_ID=5edab6d7-5946-43f4-b8c7-06b29c272bdd
REDIRECT_URL=http://localhost:5000/payment-success

# vPOS Terminal Configuration
# Supported providers: DSK, FIBANK, KBC, PAYSERA
VPOS_PROVIDER=DSK

# DSK Bank vPOS Configuration
DSK_MERCHANT_ID=merchant_001
DSK_API_KEY=your_dsk_api_key
DSK_OUTLET_ID=your_dsk_outlet_id
DSK_BASE_URL=https://api.dsk.bg/vpos

# Fibank vPOS Configuration
FIBANK_MERCHANT_ID=merchant_002
FIBANK_API_KEY=your_fibank_api_key
FIBANK_OUTLET_ID=your_fibank_outlet_id
FIBANK_BASE_URL=https://api.fibank.bg/vpos

# KBC Bank vPOS Configuration
KBC_MERCHANT_ID=merchant_003
KBC_API_KEY=your_kbc_api_key
KBC_OUTLET_ID=your_kbc_outlet_id
KBC_BASE_URL=https://api.kbc.bg/vpos

# Paysera vPOS Configuration
PAYSERA_PROJECT_ID=your_project_id
PAYSERA_MERCHANT_ID=merchant_004
PAYSERA_API_KEY=your_paysera_api_key
PAYSERA_OUTLET_ID=your_paysera_outlet_id
PAYSERA_BASE_URL=https://www.paysera.com/api/v1

# Open Banking Pre-Authentication Configuration
OPEN_BANKING_ENABLED=True
PRE_AUTH_SESSION_TIMEOUT=86400  # 24 hours in seconds
SCA_METHOD_DEFAULT=SMS_OTP

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Web3/Crypto Configuration (if needed)
WEB3_PROVIDER=http://localhost:8545
NETWORK_ID=1
PRIVATE_KEY=your_private_key_here

# Security
CORS_ENABLED=True
CORS_ORIGINS=*
SECURE_HEADERS_ENABLED=True
SESSION_TIMEOUT=3600  # 1 hour

# Database Configuration (if using SQLAlchemy)
DATABASE_URL=sqlite:///vpos_terminal.db
SQLALCHEMY_TRACK_MODIFICATIONS=False

# Email Configuration (for OTP notifications)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@vposterminal.com

# Webhook Configuration
WEBHOOK_URL=http://localhost:5000/webhooks
WEBHOOK_SECRET=your_webhook_secret

# API Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Testing
TEST_MODE=False
TEST_CARD_NUMBER=4532015112830366
TEST_EXPIRY_DATE=12/25
TEST_CVV=123
